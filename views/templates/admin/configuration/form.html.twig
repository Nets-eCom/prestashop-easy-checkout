{% extends '@PrestaShopCore/Admin/layout.html.twig' %}

{% form_theme configurationForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' '@Modules/nexi_checkout/views/templates/admin/configuration/_form_theme.html.twig' %}

{% block content %}
  {{ form_start(configurationForm) }}
  <div class="card">
    <h3 class="card-header">
      <i class="material-icons">settings</i> {{ 'Nexi Checkout Configuration'|trans({}, 'Modules.Nexicheckout.AdminConfiguration') }}
    </h3>
    <div class="card-body">
      <div class="form-wrapper">
        {{ form_widget(configurationForm) }}
      </div>
    </div>
    <div class="card-footer">
      <div class="d-flex justify-content-end">
        <button class="btn btn-primary float-right" id="save-button">
          {{ 'Save'|trans({}, 'Admin.Actions') }}
        </button>
      </div>
    </div>
  </div>
  {{ form_end(configurationForm) }}
{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link href="{{ asset('../modules/nexi_checkout/views/css/paymentMethodsManager.css') }}" rel="stylesheet">
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="{{ asset('../modules/nexi_checkout/views/js/configurationForm.js') }}"></script>
  <script src="{{ asset('../modules/nexi_checkout/views/js/paymentMethodsManager.js') }}" defer></script>
{% endblock %}
